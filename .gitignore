# ═══════════════════════════════════════════════════════════════════
# .gitignore — Cloud Shield | TP Final YNOV
# ═══════════════════════════════════════════════════════════════════

# ── Terraform — State & Cache ──────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.*
*.tfstate.lock.info
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# ── Terraform — Secrets (NE JAMAIS COMMITER) ──────────────────────
*.tfvars
*.tfvars.json

# Exception : valeurs non-sensibles commitables
!terraform/variables.auto.tfvars
!variables.auto.tfvars

# ── Infracost ──────────────────────────────────────────────────────
.infracost/

# Rapports JSON bruts (trop verbeux pour Git, générés localement)
security/infracost-current.json
security/tfsec-report.json
security/tflint-report.json
security/tflint-report.txt
security/infracost-current.txt
security/results_json.json
security/results_cli.txt
security/gitleaks-report.json

# Scripts de génération de rapports (locaux uniquement)
security/*.sh

# ── Fichiers de travail locaux ─────────────────────────────────────
TP-Final-SOUTENANCE.md
*-SOUTENANCE.md
TODO-LOCAL.md
DEPLOY-EXPENSIVE-RESOURCES.sh
*.sh

# ── Fichiers de projet internes ────────────────────────────────────
info-project-cloudshiel.md
task-project-cloudshield.md

# ── Claude — Mémoire de session ────────────────────────────────────
Claude/

# ── IDE & OS ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

